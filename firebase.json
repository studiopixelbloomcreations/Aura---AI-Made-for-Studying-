{
  "hosting": [
    {
      "target": "aevra-ai-official",
      "public": ".",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "**/venv/**",
        "**/__pycache__/**",
        "**/*.py",
        "**/*.pyc",
        "api/**",
        "functions/**",
        "netlify/**",
        "src/**",
        "gemini_clone_ui/src/**",
        "gemini_clone_ui/node_modules/**",
        "gemini_clone_ui/dist/**",
        "ExamMode/**",
        "exam_mode/**",
        "desktop/**",
        "tmp_media/**",
        "**/*.ps1",
        "**/*.bat",
        "**/*.exe"
      ],
      "rewrites": [
        {
          "source": "/",
          "destination": "/index.html"
        },
        {
          "source": "**",
          "destination": "/app.html"
        }
      ]
    }
  ]
}
