# Groq LLM API key (required)
GROQ_API_KEY=

# ElevenLabs TTS API key (required for voice)
ELEVENLABS_API_KEY=

# Supabase project URL and keys
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Comma-separated CORS origins, for example:
# http://localhost:5500,https://aevra-ai.netlify.app
ALLOWED_ORIGINS=

# OpenRouter key for Agent Harmony fallback
OPENROUTER_API_KEY=

# Puter.js key if your deployment uses keyed Puter APIs
PUTER_API_KEY=

# FastAPI backend URL used by Netlify voice proxy
FASTAPI_BASE_URL=
